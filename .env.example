# Leave blank for local dev - Vite's proxy (vite.config.ts) forwards /api
# to http://localhost:5000 automatically.
# Set this once the backend is deployed on Railway, e.g.:
# VITE_API_BASE_URL=https://tavzio-backend-production.up.railway.app
VITE_API_BASE_URL=

# Needed for two things the frontend talks to Supabase directly for (not
# through the backend): live dashboard updates (Realtime) and uploading
# logo/cover images (Storage). Same values as the backend's SUPABASE_URL /
# SUPABASE_ANON_KEY - the anon key is meant to be public, safe to expose here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
